<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Chili.ViewModels"
             xmlns:sys="using:System"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="360" d:DesignHeight="260"
             x:Class="Chili.Views.RsPriceCard"
             x:DataType="vm:RsPriceCardViewModel">

    <Design.DataContext>
        <vm:RsPriceCardViewModel/>
    </Design.DataContext>

    <UserControl.Styles>
        <!-- Accent (not the default red) focus ring on the search field. -->
        <Style Selector="TextBox#SearchBox /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="TextBox#SearchBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}"/>
        </Style>
        <Style Selector="TextBox#SearchBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Styles>

    <Border Width="360" Background="{StaticResource SurfaceBrush}" CornerRadius="16"
            BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1"
            ClipToBounds="True" VerticalAlignment="Top"
            BoxShadow="0 8 24 0 #70000000">
        <StackPanel>
            <!-- accent header line -->
            <Border Height="3" Background="{StaticResource AccentBrush}"/>

            <!-- search row -->
            <Border Padding="12,12,12,6">
                <TextBox Name="SearchBox" Text="{Binding SearchText, Mode=TwoWay}"
                         Watermark="Search RuneScape item price…"
                         Background="{StaticResource Surface2Brush}"
                         Foreground="{StaticResource TextHiBrush}"
                         BorderThickness="0" CornerRadius="10"
                         Padding="10,8" FontSize="14">
                    <TextBox.KeyBindings>
                        <KeyBinding Gesture="Enter" Command="{Binding SearchCommand}"/>
                    </TextBox.KeyBindings>
                    <TextBox.InnerLeftContent>
                        <PathIcon Width="14" Height="14" Margin="8,0,0,0"
                                  Foreground="{StaticResource TextLowBrush}"
                                  Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"/>
                    </TextBox.InnerLeftContent>
                </TextBox>
            </Border>

            <!-- recent searches (clickable chips) -->
            <Border Padding="12,0,12,8" IsVisible="{Binding HasRecent}">
                <ItemsControl ItemsSource="{Binding Recent}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="sys:String">
                            <Button Content="{Binding}" Margin="0,0,6,6" Padding="9,4" FontSize="11"
                                    CornerRadius="9" BorderThickness="0"
                                    Background="{StaticResource Surface2Brush}"
                                    Foreground="{StaticResource TextMidBrush}"
                                    CommandParameter="{Binding}"
                                    Command="{Binding ((vm:RsPriceCardViewModel)DataContext).SearchRecentCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- content area (states stacked; one visible at a time) -->
            <Panel Margin="14,2,14,16" MinHeight="34">
                <!-- idle -->
                <TextBlock IsVisible="{Binding IsIdle}"
                           Text="Type an item and press Enter for its GE price"
                           Foreground="{StaticResource TextMidBrush}" FontSize="13"
                           TextWrapping="Wrap"/>

                <!-- loading -->
                <StackPanel IsVisible="{Binding IsLoading}" Orientation="Horizontal" Spacing="12"
                            VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="120" Height="3" Margin="0"
                                 Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="Searching…" Foreground="{StaticResource TextMidBrush}" FontSize="13"/>
                </StackPanel>

                <!-- empty / error message -->
                <TextBlock IsVisible="{Binding IsMessage}" Text="{Binding MessageText}"
                           Foreground="{StaticResource TextMidBrush}" FontSize="13"
                           TextWrapping="Wrap"/>

                <!-- result -->
                <StackPanel IsVisible="{Binding IsResult}" Spacing="10">
                    <Grid ColumnDefinitions="56,12,*">
                        <Panel Grid.Column="0" Width="56" Height="56" VerticalAlignment="Top">
                            <Border Background="{StaticResource Surface2Brush}" CornerRadius="8"
                                    IsVisible="{Binding !HasThumb}">
                                <PathIcon Width="24" Height="24" Foreground="#55606A"
                                          Data="M2,2V8H4V4H8V2H2M16,2V4H20V8H22V2H16M12,7A5,5 0 0,0 7,12A5,5 0 0,0 12,17A5,5 0 0,0 17,12A5,5 0 0,0 12,7M12,9A3,3 0 0,1 15,12A3,3 0 0,1 12,15A3,3 0 0,1 9,12A3,3 0 0,1 12,9M2,16V22H8V20H4V16H2M20,16V20H16V22H22V16H20Z"/>
                            </Border>
                            <Border CornerRadius="8" ClipToBounds="True" IsVisible="{Binding HasThumb}">
                                <Image Source="{Binding Thumb}" Stretch="Uniform"/>
                            </Border>
                        </Panel>

                        <StackPanel Grid.Column="2" Spacing="2">
                            <TextBlock Text="{Binding ItemName}" Foreground="{StaticResource TextMidBrush}"
                                       FontSize="13" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="{Binding PriceText}" Foreground="{StaticResource AccentBrush}"
                                           FontSize="24" FontWeight="Bold"/>
                                <Button Name="CopyBtn" ToolTip.Tip="Copy price" VerticalAlignment="Center"
                                        Padding="6,3" CornerRadius="7" FontSize="11"
                                        Background="{StaticResource Surface2Brush}"
                                        Foreground="{StaticResource TextMidBrush}" BorderThickness="0">
                                    <PathIcon Width="13" Height="13"
                                              Data="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z"/>
                                </Button>
                                <Button ToolTip.Tip="Refresh price" VerticalAlignment="Center"
                                        Command="{Binding RefreshCommand}"
                                        Padding="6,3" CornerRadius="7" FontSize="11"
                                        Background="{StaticResource Surface2Brush}"
                                        Foreground="{StaticResource TextMidBrush}" BorderThickness="0">
                                    <PathIcon Width="13" Height="13"
                                              Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"/>
                                </Button>
                            </StackPanel>
                            <TextBlock Text="{Binding VolumeText}" Foreground="{StaticResource TextLowBrush}"
                                       FontSize="11"/>
                            <TextBlock Text="{Binding AsOfText}" IsVisible="{Binding HasAsOf}"
                                       Foreground="{StaticResource TextLowBrush}" FontSize="10"/>
                        </StackPanel>
                    </Grid>

                    <!-- 90-day price trend -->
                    <StackPanel IsVisible="{Binding HasSpark}" Spacing="2">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="90-day trend" FontSize="10"
                                       Foreground="{StaticResource TextLowBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding ChangeText}"
                                       Foreground="{Binding ChangeBrush}" FontSize="11"
                                       FontWeight="SemiBold"/>
                        </Grid>
                        <Panel Height="42">
                            <Path Data="{Binding Spark}" Stroke="{Binding ChangeBrush}"
                                  StrokeThickness="1.6" StrokeLineCap="Round" StrokeJoin="Round"
                                  HorizontalAlignment="Left" VerticalAlignment="Stretch"/>
                        </Panel>
                        <TextBlock Text="{Binding RangeText}" FontSize="10"
                                   Foreground="{StaticResource TextLowBrush}"/>
                    </StackPanel>

                    <TextBlock IsVisible="{Binding HasBlurb}" Text="{Binding Blurb}"
                               Foreground="{StaticResource TextMidBrush}" FontSize="12"
                               LineHeight="17" TextWrapping="Wrap"/>
                </StackPanel>
            </Panel>
        </StackPanel>
    </Border>
</UserControl>
