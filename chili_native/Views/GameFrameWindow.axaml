<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Chili.Views.GameFrameWindow"
        Title="CHILI Frame"
        SystemDecorations="None" CanResize="True"
        MinWidth="160" MinHeight="120"
        Background="Transparent" TransparencyLevelHint="Transparent"
        Topmost="True" ShowInTaskbar="False">

    <Grid RowDefinitions="34,*">
        <!-- Titlebar (drives the framed window) -->
        <Border Grid.Row="0" Name="TitleBar" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource AccentBrush}" BorderThickness="0,0,0,2">
            <Grid ColumnDefinitions="*,Auto" Margin="10,0">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">
                    <Border Width="11" Height="11" CornerRadius="3"
                            Background="{StaticResource BrandBrush}"/>
                    <TextBlock Name="TitleText" Text="CHILI" FontSize="12" FontWeight="Bold"
                               Foreground="{StaticResource TextHiBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Name="PricesBtn" Content="◈ Prices" Height="26" Padding="9,0"
                            Margin="0,0,6,0" CornerRadius="7" FontSize="11"
                            Background="{StaticResource Surface2Brush}"
                            Foreground="{StaticResource AccentBrush}"
                            BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1"
                            VerticalContentAlignment="Center"/>
                    <Button Name="CloseBtn" Content="✕" Width="34" Height="32"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource TextMidBrush}"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Border outline around the framed window; center stays transparent + hollow -->
        <Panel Grid.Row="1">
            <Border Background="Transparent"
                    BorderBrush="{StaticResource AccentBrush}" BorderThickness="6"/>
            <!-- edge resize handles (live within the 6px solid border) -->
            <Border Name="EdgeL" Width="6" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                    Background="Transparent" Cursor="LeftSide"/>
            <Border Name="EdgeR" Width="6" HorizontalAlignment="Right" VerticalAlignment="Stretch"
                    Background="Transparent" Cursor="RightSide"/>
            <Border Name="EdgeB" Height="6" VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                    Background="Transparent" Cursor="BottomSide"/>
            <!-- bottom-left corner resize grip -->
            <Border Name="GripBL" Width="20" Height="20"
                    HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Background="Transparent" Cursor="BottomLeftCorner"/>
            <!-- bottom-right corner resize grip -->
            <Border Name="GripBR" Width="20" Height="20"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Background="{StaticResource AccentBrush}" Cursor="BottomRightCorner">
                <TextBlock Text="⤡" FontSize="11" Foreground="#0E1116"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </Panel>
    </Grid>
</Window>
