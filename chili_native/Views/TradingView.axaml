<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Chili.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="720" d:DesignHeight="580"
             x:Class="Chili.Views.TradingView"
             x:DataType="vm:TradingViewModel">

    <UserControl.Styles>
        <Style Selector="Border.stat">
            <Setter Property="Background" Value="{StaticResource Surface2Brush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14,12"/>
        </Style>
        <Style Selector="Border.row:pointerover">
            <Setter Property="Background" Value="{StaticResource Surface2Brush}"/>
        </Style>
    </UserControl.Styles>

    <Border Width="720" Height="580" Background="{StaticResource SurfaceBrush}"
            CornerRadius="16" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1"
            Padding="20" BoxShadow="0 8 24 0 #70000000">
        <DockPanel LastChildFill="True">
            <!-- header -->
            <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,14">
                <TextBlock Grid.Column="0" Text="Trading" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource TextHiBrush}" VerticalAlignment="Center"/>
                <Border Grid.Column="1" HorizontalAlignment="Left" Margin="12,0,0,0"
                        CornerRadius="20" Padding="10,4" VerticalAlignment="Center"
                        Background="#16000000" BorderBrush="{Binding KillBrush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Border Width="7" Height="7" CornerRadius="4" VerticalAlignment="Center"
                                Background="{Binding KillBrush}"/>
                        <TextBlock Text="{Binding KillText}" FontSize="11" Foreground="{Binding KillBrush}"/>
                    </StackPanel>
                </Border>
                <Button Grid.Column="2" Content="↻  Refresh" Command="{Binding RefreshCommand}"
                        Padding="12,7" CornerRadius="9" Background="{StaticResource Surface2Brush}"
                        Foreground="{StaticResource AccentBrush}" BorderThickness="0"/>
            </Grid>

            <!-- stat cards -->
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,10,*,10,*" Margin="0,0,0,12">
                <Border Grid.Column="0" Classes="stat">
                    <StackPanel Spacing="3">
                        <TextBlock Text="Total equity" FontSize="11" Foreground="{StaticResource TextLowBrush}"/>
                        <TextBlock Text="{Binding TotalEquity}" FontSize="26" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Classes="stat">
                    <StackPanel Spacing="3">
                        <TextBlock Text="Buying power" FontSize="11" Foreground="{StaticResource TextLowBrush}"/>
                        <TextBlock Text="{Binding BuyingPower}" FontSize="20" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextHiBrush}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="4" Classes="stat">
                    <StackPanel Spacing="3">
                        <TextBlock Text="Cash" FontSize="11" Foreground="{StaticResource TextLowBrush}"/>
                        <TextBlock Text="{Binding Cash}" FontSize="20" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextHiBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- brokers + risk strip -->
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="2,0,2,14">
                <TextBlock Grid.Column="0" Text="{Binding Brokers}" FontSize="12"
                           Foreground="{StaticResource TextMidBrush}" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="14">
                    <TextBlock Text="{Binding OpenText}" FontSize="12" Foreground="{StaticResource TextMidBrush}"/>
                    <TextBlock Text="{Binding HeatText}" FontSize="12" Foreground="{StaticResource TextMidBrush}"/>
                </StackPanel>
            </Grid>

            <TextBlock DockPanel.Dock="Bottom" Text="{Binding Status}" FontSize="11"
                       Foreground="{StaticResource TextLowBrush}" Margin="2,10,0,0"/>

            <!-- positions -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Positions}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Spacing="2"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:PositionRow">
                            <Border Classes="row" CornerRadius="9" Padding="12,9">
                                <Grid ColumnDefinitions="64,*,Auto,80">
                                    <TextBlock Grid.Column="0" Text="{Binding Ticker}" FontSize="13"
                                               FontWeight="Bold" Foreground="{StaticResource TextHiBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12"
                                               Foreground="{StaticResource TextLowBrush}"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding EquityText}" FontSize="13"
                                               Foreground="{StaticResource TextHiBrush}"
                                               VerticalAlignment="Center" Margin="0,0,14,0"/>
                                    <TextBlock Grid.Column="3" Text="{Binding ChangeText}" FontSize="13"
                                               FontWeight="SemiBold" Foreground="{Binding ChangeBrush}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
