<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Chili.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="580"
             x:Class="Chili.Views.BrainView"
             x:DataType="vm:BrainViewModel">

    <UserControl.Styles>
        <Style Selector="Border.stat">
            <Setter Property="Background" Value="{StaticResource Surface2Brush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14,12"/>
        </Style>
    </UserControl.Styles>

    <Border Width="700" Height="580" Background="{StaticResource SurfaceBrush}"
            CornerRadius="16" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1"
            Padding="20" BoxShadow="0 8 24 0 #70000000">
        <DockPanel LastChildFill="True">
            <!-- header -->
            <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,Auto,*,Auto" Margin="0,0,0,14">
                <TextBlock Grid.Column="0" Text="Brain" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource TextHiBrush}" VerticalAlignment="Center"/>
                <Border Grid.Column="1" Margin="12,0,0,0" CornerRadius="20" Padding="10,4"
                        VerticalAlignment="Center" Background="#16000000"
                        BorderBrush="{Binding KillBrush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Border Width="7" Height="7" CornerRadius="4" VerticalAlignment="Center"
                                Background="{Binding KillBrush}"/>
                        <TextBlock Text="{Binding KillText}" FontSize="11" Foreground="{Binding KillBrush}"/>
                    </StackPanel>
                </Border>
                <Button Grid.Column="3" Content="↻  Refresh" Command="{Binding RefreshCommand}"
                        Padding="12,7" CornerRadius="9" Background="{StaticResource Surface2Brush}"
                        Foreground="{StaticResource AccentBrush}" BorderThickness="0"/>
            </Grid>

            <!-- spend stat cards -->
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,10,*,10,*" Margin="0,0,0,12">
                <Border Grid.Column="0" Classes="stat">
                    <StackPanel Spacing="3">
                        <TextBlock Text="LLM spend · 24h" FontSize="11" Foreground="{StaticResource TextLowBrush}"/>
                        <TextBlock Text="{Binding SpendTotal}" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Classes="stat">
                    <StackPanel Spacing="3">
                        <TextBlock Text="Calls · 24h" FontSize="11" Foreground="{StaticResource TextLowBrush}"/>
                        <TextBlock Text="{Binding CallsTotal}" FontSize="19" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextHiBrush}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="4" Classes="stat">
                    <StackPanel Spacing="3">
                        <TextBlock Text="Tokens · 24h" FontSize="11" Foreground="{StaticResource TextLowBrush}"/>
                        <TextBlock Text="{Binding TokensTotal}" FontSize="19" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextHiBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- per-provider + mode -->
            <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding Spend}" Margin="2,0,2,10">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><StackPanel Spacing="3"/></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:SpendRow">
                        <Grid ColumnDefinitions="90,*">
                            <TextBlock Grid.Column="0" Text="{Binding Provider}" FontSize="12"
                                       FontWeight="SemiBold" Foreground="{StaticResource TextMidBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Detail}" FontSize="12"
                                       Foreground="{StaticResource TextLowBrush}"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock DockPanel.Dock="Top" Margin="2,0,0,8" FontSize="12"
                       Foreground="{StaticResource TextLowBrush}"
                       Text="{Binding Mode, StringFormat='Context brain · {0} mode'}"/>

            <TextBlock DockPanel.Dock="Bottom" Text="{Binding Status}" FontSize="11"
                       Foreground="{StaticResource TextLowBrush}" Margin="2,10,0,0"/>

            <TextBlock DockPanel.Dock="Top" Text="Recent dispatch runs" FontSize="12"
                       FontWeight="SemiBold" Foreground="{StaticResource TextLowBrush}" Margin="2,4,0,8"/>

            <!-- recent runs -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Runs}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Spacing="2"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:RunRow">
                            <Border CornerRadius="9" Padding="12,9" Background="{StaticResource Surface2Brush}">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding Title}" FontSize="13"
                                               Foreground="{StaticResource TextHiBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Decision}" FontSize="12"
                                               FontWeight="SemiBold" Foreground="{Binding DecisionBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
