# CHILI Home Copilot - Environment Variables
# Copy this to .env and fill in your values

# â”€â”€ Local LLM (default â€” runs on Ollama, free, no API key needed) â”€â”€
# These defaults use phi4-mini via Ollama's OpenAI-compatible API.
# No changes needed if Ollama is running with `ollama pull phi4-mini`.
OLLAMA_MODEL=phi4-mini
LLM_API_KEY=ollama
LLM_MODEL=phi4-mini
LLM_BASE_URL=http://127.0.0.1:11434/v1

# â”€â”€ Cloud LLM (optional â€” faster for complex queries) â”€â”€
# Uncomment and set these to enable cloud escalation/fallback.
# OPENAI_API_KEY=sk-your-key-here

# â”€â”€ Fallback LLM (free â€” Google Gemini) â”€â”€
# Get a free API key at https://aistudio.google.com/apikey
# PREMIUM_API_KEY=your-gemini-api-key
# PREMIUM_MODEL=gemini-2.0-flash
# PREMIUM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Gmail SMTP for email-based pairing (optional)
# 1. Enable 2-Step Verification on your Google account
# 2. Go to: Google Account > Security > App passwords
# 3. Generate an app password for "Mail"
# 4. Paste the Gmail address and app password below
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASSWORD=your-gmail-app-password

# â”€â”€ SMS Trading Alerts â”€â”€
# Get notified when the AI finds opportunities, targets hit, stops triggered, etc.
# Uses the Gmail above to send free SMS via your carrier's email-to-SMS gateway.
SMS_PHONE=8509774415
SMS_CARRIER=verizon
# Supported carriers: verizon, att, tmobile, sprint, uscellular, boost, cricket, metro, mint, visible, google_fi
ALERTS_ENABLED=true

# Twilio (optional â€” more reliable than email-to-SMS, but costs ~$1/mo + $0.0079/SMS)
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+18001234567

# â”€â”€ Google OAuth SSO (Sign in with Google) â”€â”€
# 1. Go to https://console.cloud.google.com â†’ APIs & Services â†’ Credentials
# 2. Create an OAuth 2.0 Client ID (Web application)
# 3. Set authorized redirect URI: https://localhost:8000/auth/google/callback
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
# SESSION_SECRET=change-me-to-a-random-string

# â”€â”€ Database (required for local / non-Compose runs) â”€â”€
# PostgreSQL only (required). The app never uses SQLite at runtime. Legacy data/chili.db:
# merge with scripts/merge_sqlite_into_postgres.py, then archive/remove the file. See docs/DATABASE_POSTGRES.md.
#
# Docker Compose: the `chili` service forces HTTPS in docker-compose.yml (CHILI_TLS=1).
# A line like CHILI_TLS=0 here no longer affects the container TLS mode â€” use a compose override for HTTP.
#
# Docker Compose: `docker-compose.yml` sets DATABASE_URL inside containers to
# postgresql://chili:chili@postgres:5432/chili (overrides this line there).
# For uvicorn/scripts on the host, use the published port so you hit the same DB:
DATABASE_URL=postgresql://chili:chili@localhost:5433/chili
# Optional: production-shaped copy of `chili` (refreshed by scripts/refresh_staging_from_backup.ps1). For script dry-runs, you can set DATABASE_URL to this URL for the command session instead of the app default.
# Create once: CREATE DATABASE chili_staging; see docs/STAGING_DATABASE.md
# STAGING_DATABASE_URL=postgresql://chili:chili@localhost:5433/chili_staging
# Pytest: use a separate database (tests truncate tables). Do not point this at DATABASE_URL.
# Create once: CREATE DATABASE chili_test;
# TEST_DATABASE_URL=postgresql://chili:chili@localhost:5433/chili_test
# Optional: SQLAlchemy pool size. The brain worker holds many connections during parallel
# queue backtests; if the UI shows NS_ERROR_NET_TIMEOUT on /api/trading/*, raise these
# (and ensure PostgreSQL max_connections is high enough â€” default is often 100).
# DATABASE_POOL_SIZE=25
# DATABASE_MAX_OVERFLOW=55

# Pattern backtests / Brain OOS gate (optional â€” defaults are set in app/config.py)
# BACKTEST_SPREAD=0.0002          # bid/ask + slippage proxy as fraction of price
# BACKTEST_COMMISSION=0.001       # round-trip commission fraction
# BRAIN_OOS_HOLDOUT_FRACTION=0.25 # last 25% of bars = out-of-sample when evaluating patterns
# BRAIN_OOS_GATE_ENABLED=true
# BRAIN_OOS_MIN_WIN_RATE_PCT=42
# BRAIN_OOS_MAX_IS_OOS_GAP_PCT=38
# BRAIN_OOS_MIN_EVALUATED_TICKERS=2
#
# Optional stricter floors (unset = no extra rule). Setting these raises the bar for short-TF / crypto / high-vol families only.
# BRAIN_OOS_MIN_WIN_RATE_PCT_SHORT_TF=
# BRAIN_OOS_MIN_WIN_RATE_PCT_CRYPTO=
# BRAIN_OOS_MIN_WIN_RATE_PCT_HIGH_VOL_FAMILY=
# BRAIN_OOS_MIN_OOS_TRADES_SHORT_TF=       # minimum aggregate OOS trades across tickers (not per ticker)
# BRAIN_OOS_MIN_OOS_TRADES_CRYPTO=
# BRAIN_OOS_MIN_OOS_TRADES_HIGH_VOL_FAMILY=
#
# CPCV promotion gate — small-sample calibration (Q1.T1.5); see docs/CPCV_PROMOTION_GATE_RUNBOOK.md
# CHILI_CPCV_PROMOTION_GATE_ENABLED=false
# CHILI_CPCV_PURGE_FRAC=0.05
# CHILI_CPCV_EMBARGO_FRAC=0.02
# CHILI_CPCV_MIN_TRADES=15
# CHILI_CPCV_TARGET_PATHS=100
# CHILI_CPCV_MAX_LABELED_ROWS=0
#
# Extra gates (unset = disabled). These thin promotions quickly â€” only enable if you intend stricter research.
# BRAIN_OOS_MIN_EXPECTANCY_PCT=
# BRAIN_OOS_MIN_PROFIT_FACTOR=
# BRAIN_OOS_ROBUSTNESS_EXTRA_FRACTIONS=    # e.g. 0.2,0.3 â€” extra OOS holdout checks
# BRAIN_OOS_REQUIRE_ROBUSTNESS_WR_ABOVE_GATE=false
# BRAIN_OOS_BOOTSTRAP_ITERATIONS=0        # >0 adds CPU time; use with BRAIN_OOS_BOOTSTRAP_CI_MIN_WR
# BRAIN_OOS_BOOTSTRAP_CI_MIN_WR=

# Optional: attribute standalone brain-worker / scheduler learning cycles to this user id so
# mined TradingInsights appear under Discovered patterns for that account. Env aliases:
# CHILI_BRAIN_DEFAULT_USER_ID or BRAIN_DEFAULT_USER_ID.
# CHILI_BRAIN_DEFAULT_USER_ID=1

# Durable brain work ledger (event-first). See docs/TRADING_BRAIN_WORK_LEDGER.md
# BRAIN_WORK_LEDGER_ENABLED=1
# BRAIN_WORK_DELEGATE_QUEUE_FROM_CYCLE=1
# BRAIN_WORK_DISPATCH_BATCH_SIZE=8
# BRAIN_WORK_EXEC_FEEDBACK_BATCH_SIZE=3
# BRAIN_WORK_EXEC_FEEDBACK_DEBOUNCE_SECONDS=45
# BRAIN_WORK_SNAPSHOTS_OUTCOME_ENABLED=1
# Optional Docker build only: sets OCI label ``org.opencontainers.image.revision`` (``docker inspect``).
# Not read by the app. Example: $env:CHILI_GIT_COMMIT = (git rev-parse HEAD); docker compose build chili
# CHILI_GIT_COMMIT=<git-sha>
# CHILI_BRAIN_DEFAULT_USER_ID=1

# Optional: external Brain SPA (different origin, e.g. localhost:3000) calling CHILI on :8000.
# CHILI sets cookie only for https://localhost:8000 â€” SPAs on other ports cannot send chili_device_token.
# Set a long random secret and send the same value as header X-Chili-Brain-Wake-Secret on
# GET/POST /api/v1/brain-next-cycle. See docs/BRAIN_EXTERNAL_UI.md.
# BRAIN_V1_WAKE_SECRET=

# Optional: Brain HTTP service (chili-brain/) â€” see docs/DOCKER_FULL_STACK.md, docs/MIGRATION_BRAIN_SERVICE.md
# CHILI_BRAIN_INTERNAL_SECRET=   # set on brain container; same value as BRAIN_INTERNAL_SECRET in clients
# BRAIN_SERVICE_URL=http://127.0.0.1:8090
# BRAIN_INTERNAL_SECRET=          # Bearer token for POST /v1/run-learning-cycle (must match CHILI_BRAIN_INTERNAL_SECRET)
# CHILI_USE_BRAIN_SERVICE=0       # for scripts/brain_worker.py only: 1 = delegate cycle to BRAIN_SERVICE_URL

# â”€â”€ Market Data Providers â”€â”€
# Massive.com is the primary real-time provider (REST + optional WebSocket).
# Get an API key from https://massive.com
MASSIVE_API_KEY=your-massive-api-key

# Polygon.io is an optional fallback. When Massive is working, leave this off.
# Enabling Polygon adds a fallback between Massive and yfinance but adds
# complexity and connection pool overhead during heavy scans.
# USE_POLYGON=false
# POLYGON_API_KEY=your-polygon-api-key

# â”€â”€ Broker credentials â”€â”€
# Robinhood and Coinbase credentials are now managed per-user via the
# trading page UI (click the broker row to set up). The .env fallback
# below is optional and only used if no per-user credentials are saved.
# ROBINHOOD_USERNAME=
# ROBINHOOD_PASSWORD=
# ROBINHOOD_TOTP_SECRET=
# COINBASE_API_KEY=
# COINBASE_API_SECRET=
# With keys + coinbase-advanced-py installed, CHILI can merge Coinbase USD spot product_ids into the
# crypto ticker universe (prescreen / scans). No trading-page "connect" required for this merge.
# BRAIN_MERGE_COINBASE_SPOT_UNIVERSE=true
# Slots beyond brain_crypto_universe_max reserved for Coinbase-only symbols (default 600).
# BRAIN_COINBASE_UNIVERSE_EXTRA_CAP=600

# LEARNING_INTERVAL_HOURS=1       # default 1 in app â€” faster cycles if worker + data APIs keep up
# Edge-vs-luck v1 (OOS-gated repeatable-edge patterns): see brain_edge_* in app/config.py
# BRAIN_EDGE_EVIDENCE_ENABLED=1
# BRAIN_EDGE_EVIDENCE_GATE_ENABLED=0
#
# Phase 3: live/paper drift vs research (repeatable-edge promoted/live). See brain_live_drift_* in app/config.py
# BRAIN_LIVE_DRIFT_ENABLED=0
# BRAIN_LIVE_DRIFT_WINDOW_DAYS=120
# BRAIN_LIVE_DRIFT_MIN_TRADES=8
#
# Phase 4: execution robustness from linked Trade rows (same patterns). Refresh runs after live drift in learning cycle.
# BRAIN_EXECUTION_ROBUSTNESS_ENABLED=0
# BRAIN_EXECUTION_ROBUSTNESS_WINDOW_DAYS=120
# BRAIN_EXECUTION_ROBUSTNESS_MIN_ORDERS=5
# BRAIN_EXECUTION_ROBUSTNESS_WARN_FILL_RATE=0.65
# BRAIN_EXECUTION_ROBUSTNESS_CRITICAL_FILL_RATE=0.45
# BRAIN_EXECUTION_ROBUSTNESS_WARN_SLIPPAGE_BPS=35
# BRAIN_EXECUTION_ROBUSTNESS_CRITICAL_SLIPPAGE_BPS=65
# BRAIN_EXECUTION_ROBUSTNESS_LIVE_NOT_RECOMMENDED=1
# BRAIN_EXECUTION_ROBUSTNESS_FLAG_WEAK_TRUTH_LIVE=1
# BRAIN_EXECUTION_ROBUSTNESS_HARD_BLOCK_LIVE_ENABLED=0
#
# â”€â”€ Brain worker / backtest throughput (optional) â”€â”€
# BRAIN_BACKTEST_PARALLEL=20        # patterns in parallel (queue step); tune vs DATABASE_POOL_* and provider limits
# Do NOT set CHILI_MP_BACKTEST_CHILD in .env — the process pool sets it only inside worker children. If it is set for
# chili/brain/brain-worker, every process would use the tiny "child" SQLAlchemy pool and misconfigure connections.
# BRAIN_QUEUE_BACKTEST_EXECUTOR=process  # process = true multi-core (spawn); default threads (GIL-limited)
# BRAIN_QUEUE_PROCESS_CAP=16        # hard cap on process pool workers (omit = use BRAIN_BACKTEST_PARALLEL)
# BRAIN_MP_CHILD_DATABASE_POOL_SIZE=1   # SQLAlchemy pool per child process (keep small: P * (pool+overflow) < max_connections)
# BRAIN_MP_CHILD_DATABASE_MAX_OVERFLOW=2
# BRAIN_SMART_BT_MAX_WORKERS_IN_PROCESS=8  # ticker threads inside each process worker (lower than BRAIN_SMART_BT_MAX_WORKERS)
# BRAIN_QUEUE_BATCH_SIZE=100
# BRAIN_MAX_CPU_PCT=                # empty = no cap; e.g. 75 to cap workers
# BRAIN_SMART_BT_MAX_WORKERS=28     # threads per pattern for ticker backtests (parent / thread executor only)
# BRAIN_QUEUE_TARGET_TICKERS=80     # tickers per pattern in queue (more breadth, heavier per pattern)
# BRAIN_BUDGET_OHLCV_PER_CYCLE=280
# BRAIN_BUDGET_MINER_ROWS_PER_CYCLE=100000
# BRAIN_BUDGET_PATTERN_INJECTS_PER_CYCLE=32
#
# Brain I/O thread pools (provider fan-out). In Docker, set CHILI_CONTAINER_CPU_LIMIT to match deploy.cpus when cgroup quota is invisible.
# CHILI_RUNNING_IN_DOCKER=1
# CHILI_CONTAINER_CPU_LIMIT=2
# BRAIN_IO_EFFECTIVE_CPUS_OVERRIDE=
# BRAIN_SNAPSHOT_IO_WORKERS=8
# BRAIN_PREDICTION_IO_WORKERS=8
# BRAIN_IO_WORKERS_HIGH=
# BRAIN_IO_WORKERS_MED=
# BRAIN_IO_WORKERS_LOW=
# BRAIN_MARKET_SNAPSHOT_DEFER_WHILE_LEARNING_RUNNING=true
#
# Two-tier queue prescreen (cheap kill â†’ full backtest; final OOS gate unchanged)
# BRAIN_QUEUE_PRESCREEN_ENABLED=true
# BRAIN_QUEUE_PRESCREEN_TICKERS=6
# BRAIN_QUEUE_PRESCREEN_PERIOD=3mo
# BRAIN_QUEUE_PRESCREEN_MIN_WIN_RATE_PCT=45
# BRAIN_USE_GPU_ML=true             # LightGBM GPU on ML train step only (not queue backtest)
# Optional: slim run_learning_cycle (brain worker / API full cycle)
# BRAIN_INSIGHT_BACKTEST_ON_CYCLE=false   # legacy TradingInsight smart backtests (default false; queue BT is canonical)
# BRAIN_SECONDARY_MINERS_ON_CYCLE=true    # intraday/refine/exit/fakeout/synergy/etc. (false = faster cycles)
#
# Retest cadence (days until a pattern is eligible again if not boosted). Default 7; use 1â€“3 for aggressive refresh.
# BRAIN_RETEST_INTERVAL_DAYS=7
#
# When the priority queue is thin, add extra active patterns per cycle (variants first, then stalest last_backtest).
# BRAIN_QUEUE_EXPLORATION_ENABLED=true
# BRAIN_QUEUE_EXPLORATION_MAX=40

# Promoted-pattern fast eval (refreshes prediction cache between full learning cycles; web app scheduler only).
# BRAIN_FAST_EVAL_ENABLED=true
# BRAIN_FAST_EVAL_SCHEDULER_ENABLED=false
# BRAIN_FAST_EVAL_INTERVAL_MINUTES=10
# BRAIN_FAST_EVAL_MAX_TICKERS=400
#
# Evolution: variant winner score = WEIGHT_SHARPE*adj_sharpe + WEIGHT_WR*wr + WEIGHT_RETURN*avg_return_pct
# Raise BRAIN_EVOLUTION_WEIGHT_WR to favor win rate; pure WR maximization can overfit â€” keep Sharpe in the mix.
# BRAIN_EVOLUTION_WEIGHT_SHARPE=1.0
# BRAIN_EVOLUTION_WEIGHT_WR=2.0
# BRAIN_EVOLUTION_WEIGHT_RETURN=0.01
# BRAIN_EVOLUTION_MIN_TRADES=5
# BRAIN_EVOLUTION_MIN_TRADES_PENALTY=0.25

# Trading Brain neural mesh (desk + activation queue). docker-compose.yml also sets these on chili, brain-worker, scheduler-worker.
# TRADING_BRAIN_NEURAL_MESH_ENABLED=1
# TRADING_BRAIN_GRAPH_MODE=neural

# Momentum Autopilot local defaults.
# Paper automation is safe to leave on locally; it drives the simulated runner and scheduler-backed session progress.
CHILI_MOMENTUM_PAPER_RUNNER_ENABLED=true
CHILI_MOMENTUM_PAPER_RUNNER_SCHEDULER_ENABLED=true
# Live remains opt-in and should stay off until Coinbase live execution is explicitly intended.
CHILI_MOMENTUM_LIVE_RUNNER_ENABLED=false
CHILI_MOMENTUM_LIVE_RUNNER_SCHEDULER_ENABLED=false
