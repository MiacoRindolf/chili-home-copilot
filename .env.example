# CHILI Home Copilot - Environment Variables
# Copy this to .env and fill in your values

# ── Local LLM (default — runs on Ollama, free, no API key needed) ──
# These defaults use phi4-mini via Ollama's OpenAI-compatible API.
# No changes needed if Ollama is running with `ollama pull phi4-mini`.
OLLAMA_MODEL=phi4-mini
LLM_API_KEY=ollama
LLM_MODEL=phi4-mini
LLM_BASE_URL=http://127.0.0.1:11434/v1

# ── Cloud LLM (optional — faster for complex queries) ──
# Uncomment and set these to enable cloud escalation/fallback.
# OPENAI_API_KEY=sk-your-key-here

# ── Fallback LLM (free — Google Gemini) ──
# Get a free API key at https://aistudio.google.com/apikey
# PREMIUM_API_KEY=your-gemini-api-key
# PREMIUM_MODEL=gemini-2.0-flash
# PREMIUM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Gmail SMTP for email-based pairing (optional)
# 1. Enable 2-Step Verification on your Google account
# 2. Go to: Google Account > Security > App passwords
# 3. Generate an app password for "Mail"
# 4. Paste the Gmail address and app password below
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASSWORD=your-gmail-app-password

# ── SMS Trading Alerts ──
# Get notified when the AI finds opportunities, targets hit, stops triggered, etc.
# Uses the Gmail above to send free SMS via your carrier's email-to-SMS gateway.
SMS_PHONE=8509774415
SMS_CARRIER=verizon
# Supported carriers: verizon, att, tmobile, sprint, uscellular, boost, cricket, metro, mint, visible, google_fi
ALERTS_ENABLED=true

# Twilio (optional — more reliable than email-to-SMS, but costs ~$1/mo + $0.0079/SMS)
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+18001234567

# ── Google OAuth SSO (Sign in with Google) ──
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create an OAuth 2.0 Client ID (Web application)
# 3. Set authorized redirect URI: https://localhost:8000/auth/google/callback
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
# SESSION_SECRET=change-me-to-a-random-string

# ── Database (required for local / non-Compose runs) ──
# PostgreSQL only. See docs/DATABASE_POSTGRES.md for pytest and legacy SQLite import.
#
# Docker Compose: the `chili` service forces HTTPS in docker-compose.yml (CHILI_TLS=1).
# A line like CHILI_TLS=0 here no longer affects the container TLS mode — use a compose override for HTTP.
#
# Docker Compose: `docker-compose.yml` sets DATABASE_URL inside containers to
# postgresql://chili:chili@postgres:5432/chili (overrides this line there).
# For uvicorn/scripts on the host, use the published port so you hit the same DB:
DATABASE_URL=postgresql://chili:chili@localhost:5433/chili
# Optional: SQLAlchemy pool size. The brain worker holds many connections during parallel
# queue backtests; if the UI shows NS_ERROR_NET_TIMEOUT on /api/trading/*, raise these
# (and ensure PostgreSQL max_connections is high enough — default is often 100).
# DATABASE_POOL_SIZE=25
# DATABASE_MAX_OVERFLOW=55

# Optional: external Brain SPA (different origin, e.g. localhost:3000) calling CHILI on :8000.
# CHILI sets cookie only for https://localhost:8000 — SPAs on other ports cannot send chili_device_token.
# Set a long random secret and send the same value as header X-Chili-Brain-Wake-Secret on
# GET/POST /api/v1/brain-next-cycle. See docs/BRAIN_EXTERNAL_UI.md.
# BRAIN_V1_WAKE_SECRET=

# Optional: Brain HTTP service (chili-brain/) — see docs/DOCKER_FULL_STACK.md, docs/MIGRATION_BRAIN_SERVICE.md
# CHILI_BRAIN_INTERNAL_SECRET=   # set on brain container; same value as BRAIN_INTERNAL_SECRET in clients
# BRAIN_SERVICE_URL=http://127.0.0.1:8090
# BRAIN_INTERNAL_SECRET=          # Bearer token for POST /v1/run-learning-cycle (must match CHILI_BRAIN_INTERNAL_SECRET)
# CHILI_USE_BRAIN_SERVICE=0       # for scripts/brain_worker.py only: 1 = delegate cycle to BRAIN_SERVICE_URL

# ── Market Data Providers ──
# Massive.com is the primary real-time provider (REST + optional WebSocket).
# Get an API key from https://massive.com
MASSIVE_API_KEY=your-massive-api-key

# Polygon.io is an optional fallback. When Massive is working, leave this off.
# Enabling Polygon adds a fallback between Massive and yfinance but adds
# complexity and connection pool overhead during heavy scans.
# USE_POLYGON=false
# POLYGON_API_KEY=your-polygon-api-key

# ── Broker credentials ──
# Robinhood and Coinbase credentials are now managed per-user via the
# trading page UI (click the broker row to set up). The .env fallback
# below is optional and only used if no per-user credentials are saved.
# ROBINHOOD_USERNAME=
# ROBINHOOD_PASSWORD=
# ROBINHOOD_TOTP_SECRET=
# COINBASE_API_KEY=
# COINBASE_API_SECRET=

# ── Brain worker / backtest throughput (optional) ──
# BRAIN_BACKTEST_PARALLEL=14        # patterns in parallel (queue step)
# BRAIN_QUEUE_BATCH_SIZE=80
# BRAIN_MAX_CPU_PCT=                # empty = no cap; e.g. 75 to cap workers
# BRAIN_SMART_BT_MAX_WORKERS=28     # threads per pattern for ticker backtests
# BRAIN_QUEUE_TARGET_TICKERS=60     # tickers tested per pattern in queue
# BRAIN_USE_GPU_ML=true             # LightGBM GPU on ML train step only (not queue backtest)
#
# Retest cadence (days until a pattern is eligible again if not boosted). Default 7; use 1–3 for aggressive refresh.
# BRAIN_RETEST_INTERVAL_DAYS=7
#
# When the priority queue is thin, add extra active patterns per cycle (variants first, then stalest last_backtest).
# BRAIN_QUEUE_EXPLORATION_ENABLED=true
# BRAIN_QUEUE_EXPLORATION_MAX=40
#
# Evolution: variant winner score = WEIGHT_SHARPE*adj_sharpe + WEIGHT_WR*wr + WEIGHT_RETURN*avg_return_pct
# Raise BRAIN_EVOLUTION_WEIGHT_WR to favor win rate; pure WR maximization can overfit — keep Sharpe in the mix.
# BRAIN_EVOLUTION_WEIGHT_SHARPE=1.0
# BRAIN_EVOLUTION_WEIGHT_WR=2.0
# BRAIN_EVOLUTION_WEIGHT_RETURN=0.01
# BRAIN_EVOLUTION_MIN_TRADES=5
# BRAIN_EVOLUTION_MIN_TRADES_PENALTY=0.25
