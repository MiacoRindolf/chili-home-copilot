+def _decision(
+    subject_id: str,
+    config: RolloutConfig,
+    enabled: bool,
+    reason: str,
+    bucket: int | None,
+) -> dict[str, Any]:
     return {
-        "enabled": False,
-        "reason": "outside_cohort",
+        "enabled": enabled,
+        "reason": reason,
         "bucket": bucket,
+        "config_version": config.config_version,
+        "decision_id": stable_decision_id(subject_id, config.config_version),
     }
+
+
+def decide_rollout(subject_id: str, config: RolloutConfig) -> dict[str, Any]:
+    if config.kill_switch:
+        return _decision(
+            subject_id, config, False, "kill_switch", None
+        )
+
+    if subject_id in config.denylist:
+        return _decision(subject_id, config, False, "denylist", None)
+
+    if not config.enabled:
+        return _decision(subject_id, config, False, "disabled", None)
+
+    if subject_id in config.allowlist:
+        return _decision(subject_id, config, True, "allowlist", None)
+
+    bucket = stable_bucket(subject_id, config.salt)
+    if bucket < config.percentage:
+        return _decision(subject_id, config, True, "cohort", bucket)
+
+    return _decision(
+        subject_id, config, False, "outside_cohort", bucket
+    )
