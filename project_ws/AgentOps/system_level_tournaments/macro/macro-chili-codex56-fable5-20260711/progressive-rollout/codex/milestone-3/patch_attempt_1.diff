+def summarize_decisions(
+    decisions: list[dict[str, Any]],
+) -> dict[str, int]:
+    summary: dict[str, int] = {}
+    for decision in decisions:
+        reason = decision["reason"]
+        summary[reason] = summary.get(reason, 0) + 1
+    return summary
