@@ -9,3 +9,17 @@ def stable_bucket(subject_id: str, salt: str) -> int:
 
     digest = hashlib.sha256(f"{salt}:{subject_id}".encode("utf-8")).digest()
     return int.from_bytes(digest[:8], byteorder="big") % 100
+
+
+def stable_decision_id(subject_id: str, config_version: int) -> str:
+    if not isinstance(subject_id, str) or not subject_id.strip():
+        raise ValueError("subject_id must be non-empty")
+    if (
+        not isinstance(config_version, int)
+        or isinstance(config_version, bool)
+        or config_version <= 0
+    ):
+        raise ValueError("config_version must be positive")
+
+    evidence = f"rollout-decision:{config_version}:{subject_id}".encode("utf-8")
+    return hashlib.sha256(evidence).hexdigest()[:16]
