diff --git a/app/store.py b/app/store.py
--- a/app/store.py
+++ b/app/store.py
@@ -1,3 +1,32 @@
 class CheckpointStore:
     def __init__(self) -> None:
-        self.value = 0
+        self._checkpoints = {}
+        self._processed_ids = {}
+
+    def get_checkpoint(self, job_id):
+        return self._checkpoints.get(job_id, 0)
+
+    def get_processed_ids(self, job_id):
+        return frozenset(self._processed_ids.get(job_id, ()))
+
+    def is_processed(self, job_id, item_id):
+        return item_id in self._processed_ids.get(job_id, ())
+
+    def checkpoint(self, job_id, sequence):
+        current = self.get_checkpoint(job_id)
+        if sequence < current:
+            raise ValueError("checkpoint cannot move backwards")
+        self._checkpoints[job_id] = sequence
+
+    def mark_processed(self, job_id, item_id, sequence):
+        current = self.get_checkpoint(job_id)
+        if sequence < current:
+            raise ValueError("checkpoint cannot move backwards")
+        self._processed_ids.setdefault(job_id, set()).add(item_id)
+        self._checkpoints[job_id] = sequence
+
+    @property
+    def value(self):
+        if not self._checkpoints:
+            return 0
+        return max(self._checkpoints.values())
