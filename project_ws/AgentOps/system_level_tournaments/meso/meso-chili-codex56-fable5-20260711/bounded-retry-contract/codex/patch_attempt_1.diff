+        ):
+            raise ValueError("invalid retry policy")
+
+        return policy
diff --git a/app/backoff.py b/app/backoff.py
--- a/app/backoff.py
+++ b/app/backoff.py
@@ -2,4 +2,7 @@ from app.config import RetryPolicy
 
 
 def retry_delays(policy: RetryPolicy) -> tuple[int, ...]:
-    return tuple(policy.base_delay_ms * (2 ** attempt) for attempt in range(policy.max_attempts))
+    return tuple(
+        min(policy.base_delay_ms * (2 ** attempt), policy.max_delay_ms)
