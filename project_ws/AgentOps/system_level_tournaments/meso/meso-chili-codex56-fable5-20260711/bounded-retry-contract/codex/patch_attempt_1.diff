diff --git a/app/config.py b/app/config.py
--- a/app/config.py
+++ b/app/config.py
@@ -11,8 +11,21 @@ class RetryPolicy:
 
     @classmethod
     def from_mapping(cls, values: Mapping[str, str]) -> "RetryPolicy":
-        return cls(
-            max_attempts=int(values.get("MAX_ATTEMPTS", "0")),
-            base_delay_ms=int(values.get("BASE_DELAY_MS", "0")),
-            max_delay_ms=int(values.get("MAX_DELAY_MS", "0")),
-        )
+        try:
+            policy = cls(
+                max_attempts=int(values.get("MAX_ATTEMPTS", "3")),
+                base_delay_ms=int(values.get("BASE_DELAY_MS", "100")),
+                max_delay_ms=int(values.get("MAX_DELAY_MS", "1000")),
+            )
+        except (TypeError, ValueError):
+            raise ValueError("invalid retry policy") from None
+
+        if (
+            policy.max_attempts < 1
+            or policy.base_delay_ms <= 0
+            or policy.max_delay_ms <= 0
