diff --git a/domain/claims.py b/domain/claims.py
index edf304a..99ec758 100644
--- a/domain/claims.py
+++ b/domain/claims.py
@@ -1,4 +1,4 @@
-from dataclasses import dataclass
+from dataclasses import dataclass, field
 from typing import Any, Mapping
 
 
@@ -7,13 +7,42 @@ class Claims:
     subject_id: str
     tenant_id: str
     roles: tuple[str, ...]
-    token: str = ""
+    token: str = field(default="", repr=False)
 
     @classmethod
     def from_mapping(cls, value: Mapping[str, Any]) -> "Claims":
+        if not isinstance(value, Mapping):
+            raise ValueError("invalid claims")
+
+        subject_id = value.get("subject_id")
+        tenant_id = value.get("tenant_id")
+        raw_roles = value.get("roles", ())
+
+        if (
+            not isinstance(subject_id, str)
+            or not subject_id.strip()
+            or not isinstance(tenant_id, str)
+            or not tenant_id.strip()
+            or isinstance(raw_roles, (str, bytes))
+        ):
+            raise ValueError("invalid claims")
+
+        roles = []
+        seen = set()
+        try:
+            for role in raw_roles:
+                if not isinstance(role, str) or not role.strip():
+                    raise ValueError("invalid claims")
+                normalized = role.strip().lower()
+                if normalized not in seen:
+                    seen.add(normalized)
+                    roles.append(normalized)
+        except TypeError as exc:
+            raise ValueError("invalid claims") from exc
+
         return cls(
-            subject_id=str(value.get("subject_id", "")),
-            tenant_id=str(value.get("tenant_id", "")),
-            roles=tuple(value.get("roles", ())),
+            subject_id=subject_id.strip(),
+            tenant_id=tenant_id.strip(),
+            roles=tuple(roles),
             token=str(value.get("token", "")),
         )
diff --git a/domain/policy.py b/domain/policy.py
