--- a/api/handler.py
+++ b/api/handler.py
@@ -1,2 +1,16 @@
+from audit.events import record_decision
+from domain.claims import Claims
+from domain.policy import can_access
+
+
 def handle_request(claims_payload, resource, audit):
-    return {"status": 200}
+    claims = Claims.from_mapping(claims_payload)
+    allowed, reason = can_access(claims, resource)
+    record_decision(audit, claims, resource, allowed, reason)
+
+    return {
+        "status": 200 if allowed else 403,
+        "reason": reason,
+        "subject_id": claims.subject_id,
+        "tenant_id": claims.tenant_id,
+    }
