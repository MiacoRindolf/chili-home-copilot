diff --git a/domain/claims.py b/domain/claims.py
index edf304a..5a5e231 100644
--- a/domain/claims.py
+++ b/domain/claims.py
@@ -1,4 +1,4 @@
-from dataclasses import dataclass
+from dataclasses import dataclass, field
 from typing import Any, Mapping
 
 
@@ -7,13 +7,37 @@ class Claims:
     subject_id: str
     tenant_id: str
     roles: tuple[str, ...]
-    token: str = ""
+    token: str = field(default="", repr=False)
 
     @classmethod
     def from_mapping(cls, value: Mapping[str, Any]) -> "Claims":
+        if not isinstance(value, Mapping):
+            raise ValueError("invalid claims")
+        raw_subject = value.get("subject_id")
+        raw_tenant = value.get("tenant_id")
+        subject_id = raw_subject.strip() if isinstance(raw_subject, str) else ""
+        tenant_id = raw_tenant.strip() if isinstance(raw_tenant, str) else ""
+        if not subject_id or not tenant_id:
+            raise ValueError("invalid claims")
+        raw_roles = value.get("roles", ())
+        if raw_roles is None:
+            raw_roles = ()
+        elif isinstance(raw_roles, str):
+            raw_roles = (raw_roles,)
+        try:
+            role_iter = iter(raw_roles)
+        except TypeError:
+            raise ValueError("invalid claims") from None
+        roles = []
+        for role in role_iter:
+            normalized = str(role).strip().lower()
+            if normalized and normalized not in roles:
+                roles.append(normalized)
+        raw_token = value.get("token", "")
+        token = str(raw_token) if raw_token is not None else ""
         return cls(
-            subject_id=str(value.get("subject_id", "")),
-            tenant_id=str(value.get("tenant_id", "")),
-            roles=tuple(value.get("roles", ())),
-            token=str(value.get("token", "")),
+            subject_id=subject_id,
+            tenant_id=tenant_id,
+            roles=tuple(roles),
+            token=token,
         )
