__pycache__/
*.pyc
.venv/
.env

# Per-PR scratch artifacts generated by the ship-via-bridge flow
# (commit messages, PR bodies, ship scripts). Each accumulates to
# scripts/_<task>_*.{txt,md,ps1}. Keep the daemon scripts
# (_claude_daemon.ps1, _claude_pending.txt, _claude_output.txt,
# _claude_history/, _smoke_*.py) untracked too — they're operator-
# local and not part of the repo's deliverables.
scripts/_q*_*.txt
scripts/_q*_*.md
scripts/_q*_*.ps1
scripts/_smoke_*.py
scripts/_claude_pending.txt
scripts/_claude_output.txt
scripts/_claude_input.txt
scripts/_claude_daemon.log
scripts/_claude_history/
scripts/_q2*_cleanup.ps1
scripts/_perps_log_grep.ps1

# local database files (CHILI relational DB is PostgreSQL only; no runtime SQLite)
data/*.db
data/*.sqlite
data/chili.db.archived*
data/chili.db-wal.archived*
data/chili.db-shm.archived*

# ChromaDB vector store
data/chroma/

# User-uploaded images (keep .gitkeep)
data/uploads/*
!data/uploads/.gitkeep

# Intercom voice messages (keep .gitkeep)
data/voice/*
!data/voice/.gitkeep

# HTTPS certificates (local dev)
certs/
*.pem
*.key
mkcert.exe
scripts/tools/mkcert.exe
localhost+2.pem
localhost+2-key.pem

# pytest
.pytest_cache/
.coverage

# local route dumps (scripts/_dump_routes.py)
routes_dump.txt

# large local refresh logs
backtest_refresh_scheduled.log

# All log files from local runs — pytest, phase test captures, debug
# dumps, brain worker, etc. Never commit logs; they bloat the repo and
# frequently contain credentials or user data.
*.log

# Local DB backups (pg_dump output). Treat as secret — full state of the
# live trading DB. Keep them out of git even if a commit slips through.
backups/
*.dump

# Local test / debug captures (running pytest via the Claude harness
# emits transcripts to the repo root; same for quick one-off JSON dumps
# like dm.json / rq.json used by interactive debugging).
debug-*.log
dm.json
rq.json

# Local scratch shell commits
.commit_msg.txt

# Q1.T2 Gaussian HMM regime artifacts (warm-start weights; do not commit)
regime_models/

# pytest wrapper outputs (scripts/run-tests.ps1)
tests-summary.txt
tests-output.log
tests-output.err.log

# Claude bridge daemon artifacts (queue, output, history) — local-only, never commit
scripts/_claude_pending.txt
scripts/_claude_output.txt
scripts/_claude_history/
scripts/_claude_test_writehost.ps1
scripts/_claude_daemon.ps1

# Diagnostic/dispatch script outputs (per-run scratch dumps)
scripts/dispatch-debug-loaded-output.txt
scripts/dispatch-diagnose-output.txt
scripts/dispatch-mount-multirepo-output.txt
scripts/codebrain-tick-output.txt
scripts/pat-check-output.txt
scripts/pat-write-check-output.txt

# pytest scratch dumps captured to repo root during interactive runs
_pytest_*.txt
_pytest_*.log
pytest_*.txt
baseline_*.txt
after_*.txt
parse_out.txt
_tmp_audit.md
host-debug-logs/

# Per-task smoke test + diagnostic scripts (kept locally, never committed)
scripts/_smoke_*.py
scripts/_diag_*.py
.pr_body.md
