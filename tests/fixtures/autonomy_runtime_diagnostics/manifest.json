    {
      "case": "cases/db-queue-402.json",
      "oracle": "oracles/db-queue-402.json",
      "split": "holdout"
    },
    {
      "case": "cases/runtime-retraction-403.json",
      "oracle": "oracles/runtime-retraction-403.json",
      "split": "holdout"
    }
  ]
}
